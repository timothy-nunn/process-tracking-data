*f_a_tf_turn_cable_space_extra_void = 
* DESCRIPTION:   Void fraction of TF coil cable excluding the cooling pipe
* JUSTIFICATION: There is no coolant space in the MIT VIPER cable design other
*                than the central cooling pipe. So f_a_tf_turn_cable_space_extra_void should then be 0.
*                However about 5% of the space is used by HTS tape soldering
* REFERENCE:     Zachary S Hartwig et al 2020 Supercond. Sci. Technol. 
*                in press https://doi.org/10.1088/1361-6668/abb8c0

*f_a_tf_turn_cable_copper = 
* DESCRIPTION:   Fraction of copper in TF cable space
* JUSTIFICATION: The HTS scaling is not defined separating SC material from 
*                Copper at the HTS strands level. Therefore this Cu fraction
*                DOES NOT inclide the strand copper.
* REFERENCE:     Zachary S Hartwig et al 2020 Supercond. Sci. Technol. 
*                in press https://doi.org/10.1088/1361-6668/abb8c0

*~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~ Sliding Joints ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
*‾‾‾‾‾‾‾‾‾‾‾‾‾‾‾‾‾‾‾‾‾‾‾‾‾‾‾‾‾‾‾‾‾‾‾‾‾‾‾‾‾‾‾‾‾‾‾‾‾‾‾‾‾‾‾‾‾‾‾‾‾‾‾‾‾‾‾‾‾‾‾‾‾‾‾‾‾‾‾‾‾‾‾

i_cp_joints = 0
* DESCRIPTION:   Presence of TF sliding joints
* JUSTIFICATION: No sliding joints on the TF design

*th_joint_contact = 
* DESCRIPTION:   TF sliding joints contact pad width [m]
* JUSTIFICATION: No sliding joints on the TF design

*n_tf_joints_contact = 
* DESCRIPTION:   Number of contacts per sliding joint turn
* JUSTIFICATION: No sliding joints on the TF design

*n_tf_joints = 
* DESCRIPTION:   Number of joints per turn
* JUSTIFICATION: No sliding joints on the TF design

* rho_tf_joints  = 
* DESCRIPTION:   TF joints surfacic resistivity [ohm.m]. Feldmetal joints assumed.
* JUSTIFICATION: Not yet set, assuming default.

*~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~ Stress Limits ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
*‾‾‾‾‾‾‾‾‾‾‾‾‾‾‾‾‾‾‾‾‾‾‾‾‾‾‾‾‾‾‾‾‾‾‾‾‾‾‾‾‾‾‾‾‾‾‾‾‾‾‾‾‾‾‾‾‾‾‾‾‾‾‾‾‾‾‾‾‾‾‾‾‾‾‾‾‾‾‾‾‾‾‾

*-----------------*
* Inboard Support *
*-----------------*

i_tf_bucking = 1
* DESCRIPTION:   Bucking strategy
* JUSTIFICATION: Bucked on centering support

eyoung_res_tf_buck = 205.0E9   * Pa
* DESCRIPTION:   TF bucking cylinder young modulus
* JUSTIFICATION: Choice of material : Steel, as it is a good support material
*                and its has a rather low conductivity for CS flux propagation

*-------------------*
* Inboard Mid-Plane *
*-------------------*

f_vforce_inboard = 0.5
* DESCRIPTION:   Fraction of the vertical tension taken by the inboard mid-plane
* JUSTIFICATION: 

*str_tf_con_res = 
* DESCRIPTION:   Residual manufacturing strain in TF superconductor material
* JUSTIFICATION: Not set, assuming default

*i_str_wp = 
* DESCRIPTION:   Switch for the behavior of the TF strain used to compute
* the strain-dependent critical surface: 
* =0  str_tf_con_res is used
* =1  str_wp is used
* JUSTIFICATION: Not set, assuming default

i_tf_tresca = 0
* DESCRIPTION:   Switch for TF coil conduit TRESCA stress criterion
* JUSTIFICATION: We only considers the inboard mid-plane stress on this study
*                no need to bother with the maximum stress correction from CEA

*n_tf_graded_layers
* DESCRIPTION:   Number of layers of different stress properties in the WP. If n_tf_graded_layers > 1,
* a graded coil is considered. (default = 100)
* JUSTIFICATION: Not set, assuming default

*n_rad_per_layer
* DESCRIPTION:   Size of the arrays per layers storing the radial dependent stress
* quantities (stresses, strain displacement etc..)
* JUSTIFICATION: Not set, assuming default

i_tf_stress_model = 0
* DESCRIPTION:   Choice of the stress calculation model (0: generalized plane strain)
*= 0 : Generalized plane strain formulation, Issues #977 and #991, O(n^3)
*= 1 : Old plane stress model (only for SC)
*= 2 : Axisymmetric extended plane strain, Issues #1414 and #998, O(n)
* JUSTIFICATION: 

*~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~

icc = 31
* DESCRIPTION:   TF coil case stress upper limit
* JUSTIFICATION: The support structure must hold
* VARIABLES:     sig_tf_case calculated in-situ

sig_tf_case_max = 850.0E6 
* DESCRIPTION:   Allowable Tresca stress in TF coil structural material (Pa) (icc=31)
* JUSTIFICATION: Stress limit increased as required to match TF coil design finite 
*                element modelling shows PROCESS maybe conservative in stress calculations

*~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~

icc = 32
* DESCRIPTION:   TF WP steel jacket/conduit stress upper limit
* JUSTIFICATION: Stress limits must hold
* VARIABLES:     sig_tf_wp calculated in-situ

sig_tf_wp_max = 700.0E6 
* DESCRIPTION:   Allowable Tresca stress in TF coil winding pack (Pa) (icc=32)
* JUSTIFICATION: Stress limit increased as required to match TF coil design finite 
*                element modelling shows PROCESS maybe conservative in stress calculations

*~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~

*i_tf_cond_eyoung_axial =
* DESCRIPTION:   Switch for the behavior of the TF coil conductor elastic axial properties (default = 0)
* =0  Young's modulus is set to zero, and the conductor is not considered
*     in the stress calculation. This corresponds to the case that the
*     conductor is much less stiff than the conduit, or the case that the
*     conductor is prevented (isolated) from taking axial loads.
* =1  Elastic properties are set by user input, using the variable                MAY BE OBSOLETE
*     `eyoung_cond_axial`
* =2  Elastic properties are set to reasonable defaults taking into
*     account the superconducting material `i_tf_sc_mat`
* JUSTIFICATION: Not yet set, assuming default, 

*i_tf_cond_eyoung_trans =
* DESCRIPTION:   Switch for the behavior of the elastic properties of the TF coil conductor in the transverse direction.
*  Only active if i_tf_cond_eyoung_axial == 2
* =0  Cable not potted in solder. Transverse Young's modulus set to zero.
* =1  Cable potted in solder. If i_tf_cond_eyoung_axial == 2, the
*     transverse Young's modulus of the conductor is equal to the axial,       MAY BE OBSOLETE
*     which is set to a sensible material-dependent default.`
* JUSTIFICATION: Not yet set, assuming default

*~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~

*icc = 65
* DESCRIPTION:   Constraint equation for the stress of the vacuum vessel that occurs when the TF coil quenches.
* JUSTIFICATION: Turned off, don't care about quenching scenario
* VARIABLES:     max_vv_stress (Maximum permitted stress of the VV (Pa)), vv_stress_quench calculated in-situ

*max_vv_stress =  
* DESCRIPTION:   The allowable peak maximum shear stress in the vacuum vessel due to quench and fast discharge of the TF coils [Pa] (icc = 65)
* (default = 143.0D6)
* JUSTIFICATION: Not yet set, assuming default

* theta1_coil  = 
* DESCRIPTION:   The angle of the outboard arc forming the TF coil current center line (deg) (default = 45 degrees)
* JUSTIFICATION: Not yet set, assuming default.

* theta1_vv  = 
* DESCRIPTION:   The angle of the outboard arc forming the VV current center line (deg) (default = 1 degrees)
* JUSTIFICATION: Not yet set, assuming default.

*~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~

*icc = 25
* DESCRIPTION:   Constraint equation for peak toroidal field upper limit 
* JUSTIFICATION: Turned off, don't care toridal field limit
* VARIABLES:     b_tf_inboard_peak_symmetric calculated in-situ

* b_tf_inboard_max  = 
* DESCRIPTION:   Maximum peak toroidal field (T) (`constraint equation 25`) (default = 12)
* JUSTIFICATION: Not yet set, assuming default.

*~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~

*icc = 88
* DESCRIPTION:   Constraint equation for TF coil vertical strain upper limit (absolute value)
* JUSTIFICATION: Turned off, not concerned with TF coil vertical strain
* VARIABLES:     str_wp_max (Allowable maximum TF coil vertical strain). str_wpcrypmw calculated in-situ

*str_wp_max = 
* DESCRIPTION: Maximum allowed absolute value of the strain in the TF coil
