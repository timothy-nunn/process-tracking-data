* JUSTIFICATION: testing

*conf_mag = 
* DESCRIPTION: c parameter, which determines the temperature margin at which magnet lifetime starts to decline
* JUSTIFICATION: testing

*div_prob_fail = 
* DESCRIPTION: Divertor probability of failure (per op day)
* JUSTIFICATION: testing

*div_umain_time = 
* DESCRIPTION: Divertor unplanned maintenance time (years)
* JUSTIFICATION: testing

*div_nref = 
* DESCRIPTION: Reference value for cycle life of divertor
* JUSTIFICATION: testing

*div_nu = 
* DESCRIPTION: The cycle when the divertor fails with 100% probability
* JUSTIFICATION: testing

*fwbs_nref = 
* DESCRIPTION: Reference value for cycle life of blanket
* JUSTIFICATION: testing

*fwbs_nu = 
* DESCRIPTION: The cycle when the blanket fails with 100% probability
* JUSTIFICATION: testing

*fwbs_umain_time = 
* DESCRIPTION: Fwbs unplanned maintenace time (years)
* JUSTIFICATION: testing

*fwbs_prob_fail = 
* DESCRIPTION: Fwbs probability of failure (per op day)
* JUSTIFICATION: testing

*redun_vacp = 
* DESCRIPTION: Vacuum system pump redundancy level (%)
* JUSTIFICATION: testing

*t_blkt_replace_yrs = 
* DESCRIPTION: Time needed to replace blanket (yr)
* JUSTIFICATION: testing

*tcomrepl = 
* DESCRIPTION: Time needed to replace blanket+divertor (yr)
* JUSTIFICATION: testing

*t_div_replace_yrs = 
* DESCRIPTION: Time needed to replace divertor (yr)
* JUSTIFICATION: testing

*life_plant = 
* DESCRIPTION: Plant life (yr)
* JUSTIFICATION: testing

*uubop = 
* DESCRIPTION: Unplanned unavailability for BOP
* JUSTIFICATION: testing

*uucd = 
* DESCRIPTION: Unplanned unavailability for CD system
* JUSTIFICATION: testing

*uudiv = 
* DESCRIPTION: Unplanned unavailability for divertor
* JUSTIFICATION: testing

*uufuel = 
* DESCRIPTION: Unplanned unavailability for fuel system
* JUSTIFICATION: testing

*uufw = 
* DESCRIPTION: Unplanned unavailability for first wall
* JUSTIFICATION: testing

*uumag = 
* DESCRIPTION: Unplanned unavailability for magnets
* JUSTIFICATION: testing

*uuves = 
* DESCRIPTION: Unplanned unavailability for vessel
* JUSTIFICATION: testing


