temp_plasma_electron_vol_avg_kev = 7.0  *Volume averaged electron temperature (keV)
boundl(4) = 3.
boundu(4) = 15.

ixc = 6                 *dene
nd_plasma_electrons_vol_avg = 2.0E20    *Electron density (/m3)
boundl(6) = 3.00E19
boundu(6) = 3.00E20

ixc = 10                *hfact
